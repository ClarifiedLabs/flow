# Copy this file to .env before running Docker Compose.
# Use an absolute path; Docker Compose does not expand ~ in bind mounts.
# Example: FLOW_CODEX_AUTH_JSON=/Users/example/.codex/auth.json
FLOW_CODEX_AUTH_JSON=

# Generate this with `claude setup-token` from a Claude Code subscription account.
CLAUDE_CODE_OAUTH_TOKEN=

# Harness model proxy running on the Docker host.
HARNESS_MODEL_PROXY_URL=http://host.docker.internal:8765

# Reusable secret that lets workers join the server and receive worker tokens.
# Generate with: openssl rand -hex 32
FLOW_WORKER_JOIN_TOKEN=

# Owner-scoped secret for human/admin CLI and web UI bootstrap.
# Generate with: openssl rand -hex 32
FLOW_OWNER_TOKEN=

# Non-root UID/GID used by the flow-server and flow-worker containers.
FLOW_UID=1000
FLOW_GID=1000

# URL written into project exchange remotes for host CLI access.
FLOW_EXCHANGE_BASE_URL=http://127.0.0.1:8421

# URL the worker uses inside the Docker Compose network.
FLOW_WORKER_INTERNAL_BASE_URL=http://flow-server:8421

# Terminal proxy target registered by the worker. "auto" uses the worker
# container IP on the Compose network and binds ttyd on all container interfaces.
FLOW_WORKER_TERMINAL_PUBLIC_BASE_URL=auto
FLOW_WORKER_TERMINAL_BIND_ADDRESS=0.0.0.0

# Rootless Docker daemon startup for the worker. Use false when binding an
# external Docker socket and setting DOCKER_HOST yourself.
FLOW_WORKER_DOCKERD=auto
FLOW_WORKER_DOCKERD_ARGS=
